@startuml ACPI Toolkit

class ACPIAnalyzer {
  + run(rulePath: Path, target: List[Path] = None): DetectionResult
}

package ACPIProvider {
  class Dumper {
    + dump_acpi(output_file: str = "acpidump.bin"): Path
  }

  class Extractor {
    + extract_tables(dump_file: Path): List[Path]
  }

  class Disassembler {
    + disassemble_tables(table_files: List[Path]): List[Path]
  }

  class ProviderPipeline {
    - dumper: Dumper
    - extractor: Extractor
    - disassembler: Disassembler
    + run(): List[Path]
  }
}

package "ACPIMatcher" {
  class MatcherPipeline {
    - yaml: YamlProcessor
    - grep: ASTGrepMatcher
    - norm: JsonNormalizer
    - logic: LogicEngine
    - ret: ReturnEngine
    + execute(rulePath: Path, targets: List[Path]): bool
  }

  class YamlProcessor {
    - rule_file: Path
    + parse(): Rule
    + get_ast(rule: Rule): AstRule
    + get_logic(rule: Rule): LogicRule
    + get_return(rule: Rule): ReturnRule
    + validate(rule: Rule): bool
  }

  class ASTGrepMatcher {
    + run(ast_rule: AstRule, target: Path): RawJson
  }

  class JsonNormalizer {
    + normalize(raw: RawJson): NormalizedMatch
    + set_value(match: NormalizedMatch, key: str, value: Any): None
    + get_value(match: NormalizedMatch, key: str): Any
  }

  class LogicEngine {
    + evaluate(logic_rule: LogicRule, matches: List[NormalizedMatch], json: JsonNormalizer): void
  }

  class ReturnEngine {
    + evaluate(return_rule: ReturnRule, matches: List[NormalizedMatch]): bool
  }
}

ACPIAnalyzer --> ACPIProvider.ProviderPipeline : uses
ProviderPipeline *-- Dumper
ProviderPipeline *-- Extractor
ProviderPipeline *-- Disassembler

ACPIAnalyzer --> ACPIMatcher.MatcherPipeline : runs
ACPIMatcher.MatcherPipeline *-- ACPIMatcher.YamlProcessor
ACPIMatcher.MatcherPipeline *-- ACPIMatcher.ASTGrepMatcher
ACPIMatcher.MatcherPipeline *-- ACPIMatcher.JsonNormalizer
ACPIMatcher.MatcherPipeline *-- ACPIMatcher.LogicEngine
ACPIMatcher.MatcherPipeline *-- ACPIMatcher.ReturnEngine

ACPIMatcher.LogicEngine ..> ACPIMatcher.JsonNormalizer : mutates via set/get


@enduml
