{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "asl",
      "camelcase": "Asl",
      "title": "ACPI Source Language",
      "scope": "source.asl",
      "file-types": [
        "asl",
        "dsl"
      ],
      "injection-regex": "^asl$",
      "class-name": "TreeSitterAsl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Grammar for ACPI (ASL) code",
    "authors": [
      {
        "name": "Manuel Gil Cernich"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-asl"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}