{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "asl",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "definition_block"
      }
    },
    "_comment": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "//"
              },
              {
                "type": "PATTERN",
                "value": "[^\\n]*"
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "/*"
              },
              {
                "type": "PATTERN",
                "value": "[^*]*\\*+([^/*][^*]*\\*+)*"
              },
              {
                "type": "STRING",
                "value": "/"
              }
            ]
          }
        ]
      }
    },
    "definition_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "DefinitionBlock"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "parameters_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "FIELD",
          "name": "params",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "_expression"
                      },
                      {
                        "type": "REPEAT",
                        "content": {
                          "type": "SEQ",
                          "members": [
                            {
                              "type": "STRING",
                              "value": ","
                            },
                            {
                              "type": "SYMBOL",
                              "name": "_expression"
                            }
                          ]
                        }
                      }
                    ]
                  },
                  {
                    "type": "BLANK"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_statement"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "external_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "scope_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "device_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "method_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "return_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "field_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "name_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "assignment_stmt"
        },
        {
          "type": "SYMBOL",
          "name": "generic_call"
        }
      ]
    },
    "external_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "External"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        }
      ]
    },
    "scope_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "Scope"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "device_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "Device"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "return_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "Return"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        }
      ]
    },
    "method_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "Method"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "field_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Field"
        },
        {
          "type": "SYMBOL",
          "name": "parameters_list"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "field_element"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": ","
                  },
                  {
                    "type": "SYMBOL",
                    "name": "field_element"
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "field_element": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "field_offset"
        },
        {
          "type": "SYMBOL",
          "name": "field_named_entry"
        },
        {
          "type": "SYMBOL",
          "name": "field_empty_entry"
        }
      ]
    },
    "field_offset_element": {
      "type": "SYMBOL",
      "name": "field_offset"
    },
    "field_named_element": {
      "type": "SYMBOL",
      "name": "field_named_entry"
    },
    "field_empty_element": {
      "type": "SYMBOL",
      "name": "field_empty_entry"
    },
    "field_offset": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Offset"
        },
        {
          "type": "SYMBOL",
          "name": "parameters_list"
        }
      ]
    },
    "field_named_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "name_segs"
          }
        },
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "FIELD",
          "name": "size",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        }
      ]
    },
    "field_empty_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "FIELD",
          "name": "size",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        }
      ]
    },
    "name_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "Name"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "name_parameters"
          }
        }
      ]
    },
    "name_parameters": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "FIELD",
          "name": "variable",
          "content": {
            "type": "SYMBOL",
            "name": "name_segs"
          }
        },
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "FIELD",
          "name": "expression",
          "content": {
            "type": "SYMBOL",
            "name": "_name_expression"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "_name_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_expression"
        },
        {
          "type": "SYMBOL",
          "name": "package_initializer"
        },
        {
          "type": "SYMBOL",
          "name": "buffer_initializer"
        }
      ]
    },
    "package_initializer": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "Package"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_comma_list_block"
        }
      ]
    },
    "buffer_initializer": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "STRING",
            "value": "Buffer"
          }
        },
        {
          "type": "FIELD",
          "name": "parameters",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_comma_list_block"
        }
      ]
    },
    "_comma_list_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_name_expression"
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "SYMBOL",
                        "name": "_name_expression"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": ","
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "generic_call": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "function",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "identifier"
              },
              {
                "type": "SYMBOL",
                "name": "name_segs"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "arguments",
          "content": {
            "type": "SYMBOL",
            "name": "parameters_list"
          }
        }
      ]
    },
    "assignment_stmt": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "left",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "right",
          "content": {
            "type": "SYMBOL",
            "name": "_expression"
          }
        }
      ]
    },
    "_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "name_segs"
        },
        {
          "type": "SYMBOL",
          "name": "path_name"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "binary_expression"
        },
        {
          "type": "SYMBOL",
          "name": "generic_call"
        }
      ]
    },
    "binary_expression": {
      "type": "PREC_LEFT",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "left",
            "content": {
              "type": "SYMBOL",
              "name": "_expression"
            }
          },
          {
            "type": "FIELD",
            "name": "operator",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "STRING",
                  "value": "+"
                },
                {
                  "type": "STRING",
                  "value": "-"
                },
                {
                  "type": "STRING",
                  "value": "*"
                },
                {
                  "type": "STRING",
                  "value": "/"
                },
                {
                  "type": "STRING",
                  "value": "<<"
                },
                {
                  "type": "STRING",
                  "value": ">>"
                },
                {
                  "type": "STRING",
                  "value": "=="
                },
                {
                  "type": "STRING",
                  "value": "!="
                }
              ]
            }
          },
          {
            "type": "FIELD",
            "name": "right",
            "content": {
              "type": "SYMBOL",
              "name": "_expression"
            }
          }
        ]
      }
    },
    "number": {
      "type": "PATTERN",
      "value": "0x[0-9A-Fa-f]+|\\d+"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z]+"
    },
    "string": {
      "type": "PATTERN",
      "value": "\"[^\"]*\""
    },
    "name_segs": {
      "type": "PATTERN",
      "value": "([\\^A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*)"
    },
    "path_name": {
      "type": "PATTERN",
      "value": "(\\\\[A-Za-z0-9_]+(\\.[A-Za-z0-9_]+)*)"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "_comment"
    }
  ],
  "conflicts": [
    [
      "field_named_entry",
      "field_named_entry"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}